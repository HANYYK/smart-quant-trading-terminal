# Flask
FLASK_ENV=development
SECRET_KEY=change-this-before-production
DATABASE_URL=sqlite:///quant_trading.db

# Production example
# FLASK_ENV=production
# SECRET_KEY=<generate-with: python -c "import secrets; print(secrets.token_hex(32))">
# DATABASE_URL=sqlite:////var/www/quant_trading/instance/quant_trading.db
# DATABASE_URL=postgresql://user:password@127.0.0.1:5432/quant_trading

# Rate limit storage
# Use Redis in production if Gunicorn has multiple workers.
RATELIMIT_STORAGE_URI=memory://
# RATELIMIT_STORAGE_URI=redis://127.0.0.1:6379/0

# Cache
CACHE_DIR=./cache
CACHE_TTL=600

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
